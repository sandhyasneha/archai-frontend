From 3bc0bd9e345a28915a6682ee04a0a896c76a9ceb Mon Sep 17 00:00:00 2001
From: ram <chan2006@gmail.com>
Date: Tue, 7 Jul 2026 15:22:26 +0000
Subject: [PATCH] Restore enriched audit_findings now that schema is confirmed
 safe
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The last scan's Vercel logs show the brownfield_scans insert
succeeding (POST .../brownfield_scans -> 201 Created) with the plain
findings array, confirming the revert fixed the redirect issue.

Schema check confirms audit_findings is jsonb with no CHECK
constraints restricting its shape, so the original enrichment
(compliance_score, severity counts, cost_waste_usd, summary,
scan_summary) was safe all along — the earlier failure was likely a
transient/deployment issue, not a real schema conflict.

Re-adding the enriched shape so the Overview and Audit findings
steps show full stats again. BrownfieldDetailClient's
normaliseAudit() already supports both shapes, so this remains
backward-compatible with any rows saved during the plain-array
window.

Verified: tsc --noEmit clean, next build succeeds (20/20 pages).
---
 app/api/brownfield/analyze/route.ts | 17 ++++++++++++++++-
 1 file changed, 16 insertions(+), 1 deletion(-)

diff --git a/app/api/brownfield/analyze/route.ts b/app/api/brownfield/analyze/route.ts
index abcc975..5dc868b 100644
--- a/app/api/brownfield/analyze/route.ts
+++ b/app/api/brownfield/analyze/route.ts
@@ -102,7 +102,22 @@ export async function POST(req: NextRequest) {
             input_content: input.input_content.slice(0, 5000),
             source_cloud: scanResult.source_cloud,
             target_cloud: input.target_cloud,
-            audit_findings: auditResult.findings,
+            audit_findings: {
+              findings: auditResult.findings,
+              compliance_score: auditResult.compliance_score,
+              critical_count: auditResult.critical_count,
+              high_count: auditResult.high_count,
+              medium_count: auditResult.medium_count,
+              low_count: auditResult.low_count,
+              cost_waste_usd: auditResult.cost_waste_usd,
+              summary: auditResult.summary,
+              scan_summary: {
+                total_resources: scanResult.total_resources,
+                source_cloud: scanResult.source_cloud,
+                region: scanResult.region,
+                resources: scanResult.resources,
+              },
+            },
             migration_plan: migrationPlan,
             terraform_output: terraformOutput,
             cost_before: migrationPlan.cost_before_usd,
-- 
