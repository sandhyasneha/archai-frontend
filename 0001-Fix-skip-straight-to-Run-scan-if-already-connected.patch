From 752bfaef898395ee1d18bd67a283d7c2c2925dc7 Mon Sep 17 00:00:00 2001
From: ram <chan2006@gmail.com>
Date: Mon, 13 Jul 2026 17:03:25 +0000
Subject: [PATCH] Fix: skip straight to Run scan if already connected

Real gap flagged right after the first successful AWS connection
test but never actually fixed: every visit to the Connect AWS/Azure
panels always started the full connect flow over (Account ID entry
or Microsoft sign-in) even when a perfectly good active connection
already existed in the database. 'Connect once, scan anytime' was
always the intent, but nothing ever checked for an existing
connection before showing the start screen.

- app/api/aws-connect/status + azure-connect/status: new GET
  routes, return the user's most recent active connection (if any).
- components/brownfield/BrownfieldClient.tsx: checks both on mount
  and jumps straight to the 'connected' step (Run scan button) if
  found, skipping the connect flow entirely. Guarded so it doesn't
  fight with the Azure OAuth-redirect-restore effect if the user is
  mid-way through returning from a fresh admin consent flow.

Verified: tsc --noEmit clean, next build succeeds (2 new status
routes confirmed), no new lint errors beyond the one pre-existing
no-html-link-for-pages issue.
---
 app/api/aws-connect/status/route.ts        | 18 ++++++++++++++
 app/api/azure-connect/status/route.ts      | 18 ++++++++++++++
 components/brownfield/BrownfieldClient.tsx | 28 ++++++++++++++++++++++
 3 files changed, 64 insertions(+)
 create mode 100644 app/api/aws-connect/status/route.ts
 create mode 100644 app/api/azure-connect/status/route.ts

diff --git a/app/api/aws-connect/status/route.ts b/app/api/aws-connect/status/route.ts
new file mode 100644
index 0000000..9c0956b
--- /dev/null
+++ b/app/api/aws-connect/status/route.ts
@@ -0,0 +1,18 @@
+import { createClient } from '@/lib/supabase/server'
+
+export async function GET() {
+  const supabase = await createClient()
+  const { data: { user } } = await supabase.auth.getUser()
+  if (!user) return Response.json({ error: 'Unauthorised' }, { status: 401 })
+
+  const { data } = await supabase
+    .from('aws_connections')
+    .select('id, region')
+    .eq('user_id', user.id)
+    .eq('status', 'active')
+    .order('verified_at', { ascending: false })
+    .limit(1)
+    .single()
+
+  return Response.json({ connection: data ?? null })
+}
diff --git a/app/api/azure-connect/status/route.ts b/app/api/azure-connect/status/route.ts
